{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["npm", "nvm", "node", "github-actions"],
  "ignorePaths": [
    "docker/**",
    "manager/android",
    "manager/ios"
  ],
  "branchConcurrentLimit": 3,
  "npm": {
    "minimumReleaseAge": "7 days"
  },
  "extends": [
    "config:recommended",
    "docker:disable",
    ":approveMajorUpdates",
    ":label(dependencies)",
    ":maintainLockFilesDisabled"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "after 6pm every monday"
  ],
  "packageRules": [
    {
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "excludePackagePatterns": ["antd", "blueprint", "capacitor", "storybook", "apollo", "cypress", "axios", "recharts", "stripe"],
      "excludePackageNames": ["react", "react-dom", "klarx-tool", "pnpm"],
      "labels": ["dependencies", "run-integration-tests"],
      "matchPackagePatterns": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "groupName": "Grouped @blueprintjs",
      "matchPackagePatterns": ["@blueprintjs"],
      "additionalBranchPrefix": "{{parentDir}}/",
      "labels": ["dependencies", "run-integration-tests"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchDepTypes": ["dependencies"],
      "labels": ["dependencies", "run-integration-tests"]
    },
    {
      "extends": "packages:test",
      "groupName": "test packages",
      "labels": ["dependencies", "run-integration-tests"],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true 
    },
    {
      "matchPackagePatterns": ["cypress"],
      "labels": ["dependencies", "run-integration-tests"],
      "automerge": true
    },
    {
      "matchPackagePatterns": ["storybook"],
      "dependencyDashboardApproval": true,
      "labels": ["dependencies"]
    },
    {
      "matchPackagePatterns": ["antd"],
      "additionalBranchPrefix": "{{parentDir}}/",
      "labels": ["dependencies", "run-integration-tests"]
    },
    {
      "matchSourceUrls": [
        "https://github.com/facebook/react"
      ],
      "additionalBranchPrefix": "{{parentDir}}/",
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "run-integration-tests"]
    },
    {
      "groupName": "Grouped @capacitor",
      "matchPackagePatterns": ["capacitor"],
      "labels": ["dependencies", "run-integration-tests"],
      "schedule": [
        "every 2 months on the first day of the month"
      ]
    },
    {
      "groupName": "Grouped @apollo/client {{commitMessageExtra}}",
      "groupSlug": "apollo/client-to-{{{newVersion}}}",
      "matchPackagePatterns": ["@apollo/client"],
      "labels": ["dependencies", "run-integration-tests"]
    },
    {
      "matchPackageNames": ["bootstrap-sass"],
      "enabled": false
    },
    {
      "description": "pnpm bumps need coordinated manual updates (all packageManager fields, Docker, Semaphore); keep out of grouped minor/patch PRs.",
      "matchPackageNames": ["pnpm"],
      "groupName": "pnpm"
    },
    {
      "description": "Node version bumps need coordinated updates (.nvmrc, Docker NODE_VERSION, engines, CI); keep out of grouped minor/patch PRs.",
      "matchDepNames": ["node"],
      "matchPackageNames": [
        "node",
        "nodejs/node",
        "/(?:^|/)node$/",
        "!calico/node",
        "!kindest/node"
      ],
      "groupName": "node"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update PNPM_VERSION in Dockerfile",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "ENV\\s+PNPM_VERSION\\s+(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "pnpm",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update PNPM_VERSION in Semaphore",
      "managerFilePatterns": ["/(^|/)\\.semaphore/semaphore\\.yml$/"],
      "matchStrings": [
        "name:\\s*PNPM_VERSION\\s*\\n\\s*value:\\s*'(?<currentValue>\\d+\\.\\d+\\.\\d+)'"
      ],
      "depNameTemplate": "pnpm",
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    }
  ],
  "npmrc": "@2wunder:registry=https://npm.pkg.github.com",
  "hostRules": [
    {
      "matchHost": "github.com",
      "token": "{{ secrets.GITHUB_COM_TOKEN }}"
    },
    {
      "hostType": "npm",
      "matchHost": "npm.pkg.github.com",
      "token": "{{ secrets.GITHUB_COM_TOKEN }}"
    }
  ]
}
